    "new_testament": {
      "Matthew": "Matt.", "Mark": "Marc", "Luke": "Luc", "John": "Jean",
      "Acts": "Actes", "Romans": "Rom.", "1 Corinthians": "1 Cor.", "2 Corinthians": "2 Cor.",
