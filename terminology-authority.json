  "editorial_abbreviations": {
    "_doc": "Abréviations éditoriales : adaptation en français",
    "adapt": [
      { "source": "i.e.",  "target": "c.-à-d." },
      { "source": "e.g.",  "target": "par ex." },
      { "source": "viz.",  "target": "à savoir" },
      { "source": "No.",   "target": "nᵒ" },
      { "source": "B.C.",  "target": "av. J.-C." },
      { "source": "A.D.",  "target": "apr. J.-C." }
    ],
    "preserve_as_is": ["Heb.", "Gr.", "LXX", "cf.", "ibid.", "comp.", "q.v.", "etc."]
  },

  "bible_versions": {
    "_doc": "Versions bibliques anglaises : toujours traduire dans la prose",
    "rules": [
      { "source": "Authorized Version",  "target": "Version Autorisée King James" },
      { "source": "A.V.",                 "target": "Version Autorisée King James" },
      { "source": "Revised Version",      "target": "King James Version Révisée" },
      { "source": "R.V.",                 "target": "King James Version Révisée" },
      { "source": "in our version",       "target": "dans notre version" },
      { "source": "margin",               "target": "marge" },
      { "source": "in the margin",        "target": "en marge" }
    ]
  },

  "scholarly_apparatus": {
    "_doc": "Éléments à conserver tels quels (ne pas traduire)",
    "preserve": [
      "Titres d'ouvrages",
      "Noms d'auteurs (Josephus, Herodotus, Eusebius, Sayce, etc.)",
      "Translittérations hébraïques et grecques",
      "Références bibliographiques",
      "Sigles savants (Heb., Gr., LXX, cf., ibid., comp.)"
    ],
    "rule": "Conserver la forme de citation, traduire le texte autour"
  }
}
