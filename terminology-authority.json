{
  "_version": "2026-03-19",
  "_description": "Glossaire centralisé de traduction pour toutes les sources (Easton, Smith, ISBE, etc.). Ce fichier est la référence unique pour les substitutions terminologiques dans les pipelines de traduction. Il ne gouverne PAS l'interface (voir editorial-terminology.json).",

  "theological_terms": {
    "_doc": "Termes théologiques : traduction obligatoire dans les définitions traduites",
    "rules": [
      { "source": "God",           "target": "Elohîm",        "context": "prose courante", "notes": "Si le champ 'mot' contient 'God' : Elohîm (Dieu) à la 1re occurrence, puis Elohîm. Sinon : Elohîm uniquement. Dieux païens = dieu/dieux (minuscule). Pas quand objet d'une remarque éditoriale citée. Même logique à appliquer lors de la révision Easton." },
      { "source": "the LORD",      "target": "YHWH",           "context": "tétragramme explicite" },
      { "source": "LORD",          "target": "YHWH",           "context": "tétragramme explicite" },
      { "source": "Jehovah",       "target": "YHWH",           "context": "toujours, y compris comme composant de nom propre. Le composant hébreu adopte sa forme hébraïque (J→Y) : Jehovah-Jireh → YHWH-Yireh, Jehovah-Nissi → YHWH-Nissi, Jehovah-Shalom → YHWH-Shalom, etc." },
      { "source": "the Lord",      "target": "le Seigneur",    "context": "quand ce n'est pas le tétragramme ni une note de version" },
      { "source": "Jesus",         "target": "Yéhoshoua",      "context": "première occurrence utile : Yéhoshoua (Jésus), puis Yéhoshoua" },
      { "source": "Christ",        "target": "Mashiah (Christ)","context": "première occurrence utile, puis Mashiah seul si contexte clair" },
      { "source": "Messiah",       "target": "Mashiah",        "context": "toujours" },
      { "source": "Holy Spirit",   "target": "Saint-Esprit",   "context": "toujours" },
      { "source": "Holy Ghost",    "target": "Saint-Esprit",   "context": "toujours" }
    ]
  },

  "bible_references": {
