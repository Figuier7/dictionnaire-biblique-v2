  "proper_names": {
    "_doc": "Noms propres : forme française classique quand elle est certaine et stable",
    "rules": [
      { "source": "Jerusalem",   "target": "Jérusalem" },
      { "source": "Samaria",     "target": "Samarie" },
      { "source": "Assyria",     "target": "Assyrie" },
      { "source": "Sinai",       "target": "Sinaï" },
      { "source": "Rehoboam",    "target": "Roboam" },
      { "source": "Ephraim",     "target": "Éphraïm" },
      { "source": "Nineveh",     "target": "Ninive" },
      { "source": "Damascus",    "target": "Damas" },
      { "source": "Philistines", "target": "Philistins" },
      { "source": "Egypt",       "target": "Égypte" },
      { "source": "Babylon",     "target": "Babylone" },
